{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "out",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "Node16"
  },
  "exclude": ["node_modules", ".vscode-test", "vitest.config.ts", "vitest.coverage.config.ts", "playwright.config.ts", "scripts", "src/test"]
}
